# Sanity — usato dal sito SvelteKit per leggere mentor e talenti
# Sostituisci con il nuovo Project ID Sanity
PUBLIC_SANITY_PROJECT_ID=your-project-id
PUBLIC_SANITY_DATASET=production
PUBLIC_SANITY_API_VERSION=2025-06-15
PUBLIC_SANITY_STUDIO_URL=https://the-8th-cms.sanity.studio

# Token Viewer: necessario su Vercel per leggere il dataset privato al build
# SANITY_API_READ_TOKEN=

# Token Editor: solo per seed locale (npm run seed:sanity), non metterlo su Vercel
# SANITY_API_WRITE_TOKEN=
