    "studio": "npm run dev --prefix studio",
    "studio:deploy": "npm run deploy --prefix studio"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.8.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@sanity/client": "^7.8.0"
  }
}
